{
  "expo": {
    "name": "Lessons Mama Never Taught Me",
    "slug": "lmntm",
    "scheme": "lmntm",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#c5ced9"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.lmntm.reader",
      "buildNumber": "1",
      "infoPlist": {
        "NSAppTransportSecurity": { "NSAllowsArbitraryLoads": false }
      }
    },
    "android": {
      "package": "app.lmntm.reader",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#c5ced9"
      }
    },
    "web": { "bundler": "metro" },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": { "typedRoutes": true },
    "extra": {
      "webAppUrl": "https://lmntm.app"
    }
  }
}
