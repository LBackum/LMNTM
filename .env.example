# Copy to .env.local (web/) and fill in. NEVER commit real values.

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://lmntm.app

# -----------------------------------------------------------------------------
# Supabase  (create a project at https://supabase.com)
#   - NEXT_PUBLIC_* values are safe to expose to the browser (enforced by RLS)
#   - SUPABASE_SERVICE_ROLE_KEY bypasses RLS — server-only, never commit
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# -----------------------------------------------------------------------------
# Stripe  (https://dashboard.stripe.com/apikeys)
#   Publishable key is safe to expose; secret key is server-only.
#   Start in TEST mode (sk_test_..., pk_test_...) until flows are verified.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Email  (https://resend.com — transactional email for parent consent flow)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...
SUPPORT_EMAIL=ask@drkayjay.com

# -----------------------------------------------------------------------------
# Translation  (optional — used by /api/translate for per-chapter translation)
# Set TRANSLATION_PROVIDER to "deepl" or "google" and TRANSLATION_API_KEY to
# the matching API key. Without this, the UI surfaces a clear error.
# -----------------------------------------------------------------------------
TRANSLATION_PROVIDER=deepl
TRANSLATION_API_KEY=
